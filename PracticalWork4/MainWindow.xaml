<Window x:Class="PracticalWork4.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Практическая работа 4 Лямин Кашичкин" Height="500" Width="900"
        WindowStartupLocation="CenterScreen" Closing="Window_Closing">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
            <Button Content="Страница 1" Click="Page1Button_Click" Width="100" Margin="5" 
                    ToolTip="Перейти на первую страницу"/>
            <Button Content="Страница 2" Click="Page2Button_Click" Width="100" Margin="5" 
                    ToolTip="Перейти на вторую страницу"/>
            <Button Content="Страница 3" Click="Page3Button_Click" Width="100" Margin="5" 
                    ToolTip="Перейти на третью страницу"/>
        </StackPanel>

        <Frame x:Name="MainFrame" Grid.Row="1" NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>