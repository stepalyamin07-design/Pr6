<Page x:Class="PracticalWork4.Page2"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Страница 2" Loaded="Page_Loaded">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="200"/>
        </Grid.ColumnDefinitions>

    
        <Image Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" 
               Source="/Images/formula2.png" Height="120" Margin="5" 
               ToolTip="Система уравнений для d"/>

        <Label Grid.Row="1" Grid.Column="0" Content="Выберите f(x):" Margin="5"/>
        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="5">
            <RadioButton x:Name="rbSh" Content="sh(x)" GroupName="FuncGroup" 
                         IsChecked="True" Margin="5" ToolTip="Гиперболический синус"/>
            <RadioButton x:Name="rbX2" Content="x²" GroupName="FuncGroup" Margin="5" 
                         ToolTip="Квадрат x"/>
            <RadioButton x:Name="rbExp" Content="e^x" GroupName="FuncGroup" Margin="5" 
                         ToolTip="Экспонента"/>
        </StackPanel>

   
        <Label Grid.Row="2" Grid.Column="0" Content="x:" Margin="5"/>
        <TextBox x:Name="txtX" Grid.Row="2" Grid.Column="1" Margin="5" 
                 ToolTip="Введите x (вещественное число)"/>

    
        <Label Grid.Row="3" Grid.Column="0" Content="y:" Margin="5"/>
        <TextBox x:Name="txtY" Grid.Row="3" Grid.Column="1" Margin="5" 
                 ToolTip="Введите y"/>

    
        <Label Grid.Row="4" Grid.Column="0" Content="Результат d:" Margin="5"/>
        <TextBox x:Name="txtResult" Grid.Row="4" Grid.Column="1" Margin="5" 
                 IsReadOnly="True" Background="#F5F5F5"/>


        <StackPanel Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" 
                    Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
            <Button Content="Вычислить" Click="Calculate_Click" Width="100" Margin="5"/>
            <Button Content="Очистить" Click="Clear_Click" Width="100" Margin="5"/>
        </StackPanel>
    </Grid>
</Page>