<Page x:Class="PracticalWork4.Page1"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Страница 1" Loaded="Page_Loaded">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Изображение формулы -->
        <Image Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" 
               Source="/Images/formula1.png" Height="120" Margin="5" 
               ToolTip="Формула для вычисления g"/>

        <!-- Ввод x -->
        <Label Grid.Row="1" Grid.Column="0" Content="x:" Margin="5" 
               ToolTip="Введите значение x (вещественное число)"/>
        <TextBox x:Name="txtX" Grid.Row="1" Grid.Column="1" Margin="5" 
                 ToolTip="Введите x"/>

        <!-- Ввод y -->
        <Label Grid.Row="2" Grid.Column="0" Content="y:" Margin="5" 
               ToolTip="Введите значение y"/>
        <TextBox x:Name="txtY" Grid.Row="2" Grid.Column="1" Margin="5"/>

        <!-- Ввод z -->
        <Label Grid.Row="3" Grid.Column="0" Content="z:" Margin="5" 
               ToolTip="Введите значение z (sin(z) ≠ 0)"/>
        <TextBox x:Name="txtZ" Grid.Row="3" Grid.Column="1" Margin="5"/>

        <!-- Результат -->
        <Label Grid.Row="4" Grid.Column="0" Content="Результат g:" Margin="5"/>
        <TextBox x:Name="txtResult" Grid.Row="4" Grid.Column="1" Margin="5" 
                 IsReadOnly="True" Background="#F5F5F5" 
                 ToolTip="Результат вычисления"/>

        <StackPanel Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="3" 
                    Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
            <Button Content="Вычислить" Click="Calculate_Click" Width="100" Margin="5" 
                    ToolTip="Выполнить расчёт"/>
            <Button Content="Очистить" Click="Clear_Click" Width="100" Margin="5" 
                    ToolTip="Очистить все поля"/>
        </StackPanel>
    </Grid>
</Page>